# For the definition of this file, refer to "../../server/proto/config.proto".
#
# How to test with your own switch chassis:
#  1. Collect the serial numbers of the control cards. For fixed form factor chassis, it is the serial number of the chassis itself.
#  2. Prepare the vendor CA (Certificate Authority) certificate. This must be the vendor CA that signs the IDevID.
#  3. Generate an owner PDC (Pinned Domain Certificate) and its private key.
#  4. Generate an Owner Certificate and its private key, signed by the owner PDC.
#  5. Use the owner PDC to generate Ownership Vouchers for each of the serial numbers.
#  6. Replace corresponding artifacts below ('owner_certificate', 'vendor_ca_certs', 'ownership_voucher') with the ones you prepared.
#  7. Replace the chassis info below ('manufacturer', 'serial_number') with the real info you collected.
#  8. Put your chassis image file into '../www/' directory which will be served by the HTTP service, and then modify the 'intended_image' below ('name', 'version', 'url', 'os_image_hash') accordingly.
#  9. Populate 'boot_password_hash', 'boot_config', 'credentials', 'pathz', 'authz', 'certz_profiles' below with the actual configurations for your chassis. 
#  10. (Only applicable to chassis not having IDevID) Populate 'public_key' and 'public_key_type' below for each of the serial numbers.
# NOTE: You do not need to replace the 'trust_anchor', although you can if you really want to.

server_address: "10.0.0.1:15006"
trust_anchor: {
  cert: ""
  key: ""
}
owner_certificate: {
  cert: ""
  key: ""
}
vendor_ca_certs: ""
chassis: {
  manufacturer: "Vendor Name"
  control_cards: {
    serial_number: "1234A"
    ownership_voucher: ""
    public_key: ""
    public_key_type: KEY_UNSPECIFIED
  }
  control_cards: {
    serial_number: "1234B"
    ownership_voucher: ""
    public_key: ""
    public_key_type: KEY_UNSPECIFIED
  }
  boot_mode: BOOT_MODE_SECURE
  streaming_supported: true
  intended_image: {
    name: "Image Name"
    version: "Image Version"
    url: "http://10.0.0.1:8080/image.bin"
    os_image_hash: "29:e6:5c:29:b6:25:ec:f8:8b:4e:40:5a:02:96:77:4f:63:33:85:fb:5b:fc:99:fe:ef:02:6b:b0:3c:9a:28:a3"
    hash_algorithm: "ietf-sztp-conveyed-info:sha-256"
  }
  boot_password_hash: ""
  boot_config:  {}
  credentials: {}
  pathz: {}
  authz: {}
  certz_profiles: {}
}
test_mode: true
